{
    "name": "@meepen/poe-accountant-api-schema",
    "private": true,
    "license": "MPL-2.0",
    "version": "0.0.12",
    "description": "Common API schemas for the Path of Exile Accountant application",
    "scripts": {
        "test": "vitest run"
    },
    "type": "module",
    "files": [
        "src/**/*.ts",
        "package.json"
    ],
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        },
        "./queues/*": {
            "types": "./src/queues/*.ts",
            "import": "./src/queues/*.ts"
        },
        "./api/*": {
            "types": "./src/api/*.ts",
            "import": "./src/api/*.ts"
        }
    },
    "author": {
        "email": "meep@meepen.dev",
        "name": "Devin 'Meepen' Korb",
        "url": "https://github.com/meepen"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/poe-accountant/poe-accountant.git"
    },
    "peerDependencies": {
        "@meepen/poe-common": "workspace:*",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@types/node": "^24.11.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
