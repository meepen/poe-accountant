{
    "name": "@meepen/poe-accountant-api-schema",
    "private": true,
    "license": "MPL-2.0",
    "version": "0.0.12",
    "description": "Common API schemas for the Path of Exile Accountant application",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "prebuild": "rimraf dist",
        "build": "tsc --project tsconfig.lib.json",
        "lint": "eslint ."
    },
    "type": "module",
    "files": [
        "src/**/*.d.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "package.json"
    ],
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./dist/src/index.js",
            "require": "./dist/src/index.js"
        }
    },
    "author": {
        "email": "meep@meepen.dev",
        "name": "Devin 'Meepen' Korb",
        "url": "https://github.com/meepen"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/poe-accountant/poe-accountant.git"
    },
    "peerDependencies": {
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@types/jsdom": "^21.1.7",
        "@types/node": "^24",
        "jsdom": "^26.1.0",
        "rimraf": "^6.0.1",
        "tsx": "^4.20.3",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4",
        "typescript-eslint": "^8.53.0",
        "eslint": "^9.39.2",
        "jiti": "^2.6.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "globals": "^17.0.0"
    },
    "dependencies": {
        "@meepen/poe-common": "workspace:*"
    }
}
