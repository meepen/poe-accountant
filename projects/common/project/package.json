{
    "name": "@meepen/poe-common",
    "license": "MPL-2.0",
    "version": "2.1.0",
    "description": "Common schemas for the Path of Exile API",
    "keywords": [
        "poe",
        "pathofexile",
        "api",
        "schemas",
        "types"
    ],
    "scripts": {
        "pretest": "npm run build",
        "test": "vitest run",
        "prebuild:dev": "pnpm run scrape",
        "build:dev": "pnpm run build",
        "build": "tsc -p tsconfig.lib.json",
        "pretsc": "rimraf dist",
        "tsc": "tsc --project tsconfig.lib.json",
        "scrape": "tsx scrape-src/main.ts",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@types/jsdom": "^21.1.7",
        "@types/node": "^22.0.0",
        "axios": "^1.10.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "jsdom": "^26.1.0",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.0.1",
        "tsx": "^4.20.3",
        "typescript": "^5.8.3",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.2.4",
        "typescript-eslint": "^8.53.0",
        "eslint": "^9.39.2",
        "jiti": "^2.6.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "globals": "^17.0.0"
    },
    "type": "module",
    "files": [
        "src/**/*.d.ts",
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts",
        "!dist/**/*.test.js",
        "!dist/**/*.test.js.map",
        "!dist/**/*.test.d.ts",
        "package.json"
    ],
    "exports": {
        ".": {
            "types": "./dist/src/poe.gen.d.ts",
            "import": "./dist/src/poe.gen.js",
            "require": "./dist/src/poe.gen.js"
        },
        "./stats": {
            "types": "./dist/src/stats.d.ts",
            "import": "./dist/src/stats.js",
            "require": "./dist/src/stats.js"
        },
        "./api": {
            "types": "./dist/src/api/poe-api.d.ts",
            "import": "./dist/src/api/poe-api.js",
            "require": "./dist/src/api/poe-api.js"
        },
        "./rate-limiter": {
            "types": "./dist/src/poe-rate-limiter.d.ts",
            "import": "./dist/src/poe-rate-limiter.js",
            "require": "./dist/src/poe-rate-limiter.js"
        }
    },
    "author": {
        "email": "meep@meepen.dev",
        "name": "Devin 'Meepen' Korb",
        "url": "https://github.com/meepen"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/poe-accountant/poe-accountant.git"
    },
    "peerDependencies": {
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "reflect-metadata": "^0.2.2"
    }
}
